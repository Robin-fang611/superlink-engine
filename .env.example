# SuperLink Data Engine Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# Base API Keys (Required)
# ==============================================================================

# Serper API Key (for Google Search) - Get from https://serper.dev
SERPER_API_KEY=

# ZhipuAI API Key (for data extraction) - Get from https://open.bigmodel.cn
ZHIPUAI_API_KEY=

# ==============================================================================
# Email System Configuration (Required for automated marketing)
# ==============================================================================

# Sender email address
SENDER_EMAIL=

# Sender email password (use app-specific password if required)
SENDER_PASSWORD=

# SMTP server settings
SMTP_SERVER=
SMTP_PORT=587

# IMAP server settings
IMAP_SERVER=
IMAP_PORT=993

# ==============================================================================
# Enhanced Tools API (Optional)
# ==============================================================================

# Apollo.io API Key (for decision-maker search)
APOLLO_API_KEY=

# Snov.io API Configuration (for email verification)
SNOVIO_USER_ID=
SNOVIO_API_SECRET=

# ==============================================================================
# System Configuration
# ==============================================================================

# Application access password
APP_PASSWORD=admin123

# Proxy settings (optional)
USE_PROXY=False
HTTP_PROXY=
HTTPS_PROXY=

# ==============================================================================
# Email Verification Configuration
# ==============================================================================

# Verification timeout (seconds)
VERIFICATION_TIMEOUT=10

# Verification retry count
VERIFICATION_RETRIES=2

# ==============================================================================
# Marketing Configuration
# ==============================================================================

# Email sending interval (seconds)
EMAIL_SEND_INTERVAL=3

# Batch sending limit
BATCH_SEND_LIMIT=50

# ==============================================================================
# Database Configuration
# ==============================================================================

# Database file path
DATABASE_PATH=output/superlink.db

# ==============================================================================
# System Logs Configuration
# ==============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=output/superlink.log
